generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS & CONSTANTS
// ==========================================

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  BILLING
  VENDOR
  CUSTOMER
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum VendorUserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  ACCOUNTANT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum SubOrderStatus {
  PENDING
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  COMPLETED
  FAILED
  REVERSED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum LedgerTransactionType {
  SALE_REVENUE
  PLATFORM_COMMISSION
  SUBSCRIPTION_PAYMENT
  VENDOR_PAYOUT
  REFUND_DEDUCTION
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PaymentGateway {
  PESAPAL
  STRIPE
  MTN_MOMO
  AIRTEL_MONEY
  CASH_ON_DELIVERY
}

enum WebhookProcessStatus {
  UNPROCESSED
  PROCESSED
  FAILED
  SKIPPED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ORDER_PLACED
  LOW_STOCK
  PAYMENT_RECEIVED
  SYSTEM
}

enum DocumentType {
  NATIONAL_ID
  PASSPORT
  BUSINESS_REGISTRATION
  TAX_CERTIFICATE
  TRADING_LICENSE
  OTHER
}

enum VerificationStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// ==========================================
// NEXT-AUTH REQUIRED MODELS
// ==========================================

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// USER & CORE AUTHENTICATION SECURITY
// ==========================================

model User {
  id              String        @id @default(uuid())
  name            String
  email           String        @unique
  phone           String?
  passwordHash    String?
  avatarUrl       String?
  status          UserStatus    @default(PENDING)
  platformRole    PlatformRole?

  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  vendorId        String?
  vendorRole      VendorUserRole?
  vendorProfile   VendorProfile? @relation("VendorEmployees", fields: [vendorId], references: [id], onDelete: SetNull)
  ownedVendor     VendorProfile? @relation("VendorOwner")

  settings        UserSettings?

  accounts        Account[]
  sessions        Session[]

  vendorApplications VendorApplication[]

  customerOrders  Order[]        @relation("CustomerOrders")
  reviewsWritten  ProductReview[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@index([status])
  @@index([vendorId])
  @@index([platformRole])
}

// ==========================================
// USER SETTINGS & PREFERENCES
// ==========================================

model UserSettings {
  id                    String    @id @default(uuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName              String?
  phoneNumber           String?
  avatarUrl             String?

  currency              String    @default("UGX")
  primaryLanguage       String    @default("en")
  deliveryDistrict      String?

  momoNetwork           String?
  momoNumber            String?

  orderAlertsEmail      Boolean   @default(true)
  orderAlertsPush       Boolean   @default(true)
  securityAlertsSMS     Boolean   @default(true)
  marketingNewsletter   Boolean   @default(false)

  twoFactorEnabled      Boolean   @default(false)
  buyerProtectionEnabled Boolean  @default(true)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

// ==========================================
// VENDOR KYC / ONBOARDING
// ==========================================

model VendorApplication {
  id              String             @id @default(uuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business Info
  storeName       String
  storeSlug       String             @unique
  businessType    String             
  registrationNumber String?
  taxId           String?
  
  // Contact
  businessEmail   String
  businessPhone   String
  website         String?
  
  // Address
  streetAddress   String
  city            String             @default("Kampala")
  district        String?
  country         String             @default("Uganda")
  postalCode      String?
  
  // Operations
  productCategories String[]         @default([])
  expectedMonthlyVolume String?      
  hasPhysicalStore  Boolean          @default(false)
  storeLocation     String?
  
  // Payment Setup
  momoNetwork     String?            
  momoNumber      String?
  bankName        String?
  bankAccountName String?
  bankAccountNumber String?

  // Status
  status          VerificationStatus @default(PENDING)
  reviewerNotes   String?
  reviewedBy      String?
  reviewedAt      DateTime?
  
  // Link to created vendor profile after approval
  vendorProfileId String?           @unique
  vendorProfile   VendorProfile?     @relation(fields: [vendorProfileId], references: [id], onDelete: SetNull)
  
  // Documents
  documents       VendorDocument[]
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId])
  @@index([status])
  @@index([storeSlug])
}

model VendorDocument {
  id              String             @id @default(uuid())
  applicationId   String
  application     VendorApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  type            DocumentType
  name            String
  url             String
  mimeType        String?
  size            Int?
  
  status          VerificationStatus @default(PENDING)
  notes           String?
  
  createdAt       DateTime           @default(now())

  @@index([applicationId])
}

// ==========================================
// VENDOR / TENANT PROFILE (THE SHOPS)
// ==========================================

model VendorProfile {
  id                 String       @id @default(uuid())
  ownerId            String       @unique
  owner              User         @relation("VendorOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  storeName          String
  slug               String       @unique
  registrationNumber String?
  email              String?
  phone              String?
  website            String?
  logoUrl            String?
  bannerUrl          String?
  description        String?
  address            String?
  city               String?      @default("Kampala")
  country            String?      @default("Uganda")
  currency           String       @default("UGX")
  timezone           String       @default("Africa/Kampala")
  status             VendorStatus @default(PENDING)

  momoMerchantCode   String?
  bankAccountName    String?
  bankAccountNumber  String?
  bankName           String?

  trialEndsAt        DateTime?
  activatedAt        DateTime?
  suspendedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  // Relations
  employees          User[]                  @relation("VendorEmployees")
  products           Product[]
  subOrders          SubOrder[]
  ledgerEntries      FinancialLedger[]
  payouts            VendorPayout[]
  subscriptions      VendorSubscription[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  documents          Document[]
  vendorApplication  VendorApplication?      

  @@index([status])
  @@index([createdAt])
}

// ==========================================
// COMMERCE E-COMMERCE ENGINE (CATALOG)
// ==========================================

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  
  image       String?   
  
  parentId    String?
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[] @relation("CategoryHierarchy")
  
  products    Product[] @relation("CategoryProducts")
  subProducts Product[] @relation("ProductSubCategory")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id              String          @id @default(uuid())
  vendorId        String
  vendor          VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        ProductCategory? @relation("CategoryProducts", fields: [categoryId], references: [id], onDelete: SetNull)
  subCategoryId   String?        
  subCategory     ProductCategory? @relation("ProductSubCategory", fields: [subCategoryId], references: [id], onDelete: SetNull)

  name            String
  slug            String          @unique
  brand           String?         
  description     String?         @db.Text

  basePrice       Decimal         @db.Decimal(18, 2)
  compareAtPrice  Decimal?        @db.Decimal(18, 2) 

  inventoryCount  Int             @default(0) 
  sku             String?
  status          ProductStatus   @default(DRAFT)

  sizes           String[]        @default([]) 
  colors          String[]        @default([]) 

  specs           Json?           

  tags            String[]        @default([]) 

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  images          ProductImage[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  reviews         ProductReview[]

  @@unique([vendorId, slug])
  @@index([vendorId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([status])
}

model ProductImage {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  isFeatured Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id             String      @id @default(uuid())
  productId      String
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  sku            String      @unique
  name           String      
  price          Decimal     @db.Decimal(18, 2)
  inventoryCount Int         @default(0)
  options        Json        
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orderItems     OrderItem[]

  @@index([productId])
}

model ProductReview {
  id              String    @id @default(uuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating          Int       @default(5)
  comment         String?   @db.Text
  reply           String?   
  replyAt         DateTime?
  verifiedPurchase Boolean  @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// ==========================================
// THREE-TIER MULTI-VENDOR ORDER ENGINE
// ==========================================

model Order {
  id                String         @id @default(uuid())
  customerId        String
  customer          User           @relation("CustomerOrders", fields: [customerId], references: [id])
  
  orderNumber       String         @unique
  totalAmount       Decimal        @db.Decimal(18, 2)
  subTotal          Decimal        @db.Decimal(18, 2)
  totalShipping     Decimal        @db.Decimal(18, 2)
  taxAmount         Decimal        @default(0.00) @db.Decimal(18, 2)
  
  status            OrderStatus    @default(PENDING)
  paymentGateway    PaymentGateway
  paymentStatus     PaymentStatus  @default(PENDING)
  
  gatewayReference  String?        @unique 
  shippingAddress   String
  shippingPhone     String
  shippingEmail     String
  notes             String?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  subOrders         SubOrder[]
  orderItems        OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model SubOrder {
  id                String         @id @default(uuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorId          String
  vendor            VendorProfile  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  subOrderNumber    String         @unique 
  vendorSubTotal    Decimal        @db.Decimal(18, 2)
  vendorShipping    Decimal        @db.Decimal(18, 2) 
  vendorTotal       Decimal        @db.Decimal(18, 2)
  platformCommission Decimal       @db.Decimal(18, 2) 

  status            SubOrderStatus @default(PENDING)
  notes             String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  items             OrderItem[]

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subOrderId      String
  subOrder        SubOrder        @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  quantity        Int             @default(1)
  priceAtPurchase Decimal         @db.Decimal(18, 2)
  totalPrice      Decimal         @db.Decimal(18, 2)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([orderId])
  @@index([subOrderId])
  @@index([productId])
}

// ==========================================
// VENDOR EARNINGS & ESCROW LEDGERS
// ==========================================

model FinancialLedger {
  id              String                @id @default(uuid())
  vendorId        String
  vendor          VendorProfile         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  type            LedgerTransactionType
  amount          Decimal               @db.Decimal(18, 2)
  reference       String?               
  description     String?
  
  createdAt       DateTime              @default(now())

  @@index([vendorId])
  @@index([type])
  @@index([createdAt])
}

model VendorPayout {
  id              String        @id @default(uuid())
  vendorId        String
  vendor          VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  amount          Decimal       @db.Decimal(18, 2)
  gateway         PaymentGateway
  reference       String?       
  status          PayoutStatus  @default(PENDING)
  errorMessage    String?
  
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([vendorId])
  @@index([status])
}

// ==========================================
// PLATFORM VENDOR SUBSCRIPTIONS
// ==========================================

model SubscriptionPlan {
  id                 String             @id @default(uuid())
  name               String             @unique
  slug               String             @unique
  description        String?
  price              Decimal            @db.Decimal(18, 2)
  currency           String             @default("UGX")
  billingCycle       BillingCycle       @default(MONTHLY)

  maxProducts        Int?
  commissionRate     Decimal            @db.Decimal(5, 2)
  hasPremiumThemes   Boolean            @default(false)
  hasAdvancedCharts  Boolean            @default(false)
  isActive           Boolean            @default(true)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  subscriptions      VendorSubscription[]
}

model VendorSubscription {
  id                 String             @id @default(uuid())
  vendorId           String
  vendor             VendorProfile      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  planId             String
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])
  
  status             SubscriptionStatus @default(TRIAL)
  startedAt          DateTime           @default(now())
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  gracePeriodEndsAt  DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([vendorId])
  @@index([status])
}

// ==========================================
// SYSTEM ENGINE, AUDIT LOGS, INTEGRATIONS
// ==========================================

model Notification {
  id              String           @id @default(uuid())
  vendorId        String?
  vendor          VendorProfile?   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            NotificationType @default(INFO)
  title           String
  message         String
  readAt          DateTime?
  createdAt       DateTime         @default(now())

  @@index([vendorId])
  @@index([userId])
  @@index([readAt])
}

model Document {
  id              String       @id @default(uuid())
  vendorId        String?
  vendor          VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  type            DocumentType @default(OTHER)
  name            String
  url             String
  mimeType        String?
  size            Int?
  createdAt       DateTime     @default(now())

  @@index([vendorId])
}

model AuditLog {
  id              String         @id @default(uuid())
  vendorId        String?
  vendor          VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  action          String
  entity          String
  entityId        String?
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime       @default(now())

  @@index([vendorId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model PesapalIpnRegistry {
  id          String   @id @default(uuid())
  ipnId       String   @unique
  url         String
  environment String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ipnId])
}

model PaymentGatewayWebhookLog {
  id              String               @id @default(uuid())
  gateway         PaymentGateway
  trackingId      String
  reference       String
  eventType       String?
  payload         Json
  status          WebhookProcessStatus @default(UNPROCESSED)
  errorMessage    String?
  createdAt       DateTime             @default(now())

  @@index([trackingId])
  @@index([reference])
  @@index([status])
}